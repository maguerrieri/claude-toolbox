#!/usr/bin/env python3
"""gm adapter validator — lints adapter folders against the contract.

Checks: adapter.md exists with front-matter + a `name`; any `extends:` resolves
to a real parent (no cycles); every oracles/*.md has at least one `- ` entry with
weight >= 1; a named `sheet:` exists; and oracle files referenced in adapter.md
prose actually exist.

Usage:
  validate-adapter <adapter-dir>...
  validate-adapter --all <adapters-root>     # validate every subdir that has an adapter.md
Exit 0 if all valid; 1 (with FAIL lines) otherwise.
"""
import argparse
import glob
import os
import re
import sys

TABLE_ENTRY = re.compile(r"^- (?:\[(\d+)\]\s*)?(.*)$")


def parse_frontmatter(path):
    text = open(path).read()
    m = re.match(r"^---\n(.*?)\n---", text, re.S)
    if not m:
        return None, text
    fm = {}
    for line in m.group(1).splitlines():
        if ":" in line:
            k, v = line.split(":", 1)
            fm[k.strip()] = v.strip()
    return fm, text


def validate_table(path):
    errs, entries = [], 0
    for line in open(path).read().splitlines():
        m = TABLE_ENTRY.match(line)
        if m:
            entries += 1
            w = int(m.group(1)) if m.group(1) else 1
            if w < 1:
                errs.append(f"{path}: entry {entries} has weight {w} (must be >= 1)")
    if entries == 0:
        errs.append(f"{path}: no entries (need at least one '- ' item)")
    return errs


def validate_adapter(adapter_dir, adapters_root):
    errs = []
    name = os.path.basename(adapter_dir.rstrip("/"))
    manifest = os.path.join(adapter_dir, "adapter.md")
    if not os.path.isfile(manifest):
        return [f"{name}: missing adapter.md"]
    fm, text = parse_frontmatter(manifest)
    if fm is None:
        return [f"{name}: adapter.md is missing YAML front-matter"]
    if not fm.get("name"):
        errs.append(f"{name}: front-matter missing 'name'")

    parent, seen = fm.get("extends"), {name}
    while parent:
        if parent in seen:
            errs.append(f"{name}: extends cycle involving '{parent}'")
            break
        seen.add(parent)
        pmanifest = os.path.join(adapters_root, parent, "adapter.md")
        if not os.path.isfile(pmanifest):
            errs.append(f"{name}: extends '{parent}', which has no adapter.md")
            break
        pfm, _ = parse_frontmatter(pmanifest)
        parent = (pfm or {}).get("extends")

    for f in sorted(glob.glob(os.path.join(adapter_dir, "oracles", "*.md"))):
        errs += validate_table(f)

    sheet = fm.get("sheet")
    if sheet and not os.path.isfile(os.path.join(adapter_dir, sheet)):
        errs.append(f"{name}: sheet '{sheet}' not found")

    for ref in sorted(set(re.findall(r"oracles/([\w./-]+\.md)", text))):
        if not os.path.isfile(os.path.join(adapter_dir, "oracles", ref)):
            errs.append(f"{name}: adapter.md references oracles/{ref}, which is missing")
    return errs


# Unambiguous system-mechanic phrases a persona (voice only) must never name.
PERSONA_MECHANIC_TOKENS = [
    "ironsworn-action", "ironsworn-progress", "challenge dice",
    "strong hit", "weak hit", "progress track", "action die",
]


def validate_persona(persona_md):
    name = os.path.basename(os.path.dirname(persona_md.rstrip("/")))
    fm, text = parse_frontmatter(persona_md)
    if fm is None:
        return [f"persona {name}: persona.md is missing front-matter"]
    errs = []
    if not fm.get("name"):
        errs.append(f"persona {name}: front-matter missing 'name'")
    parts = text.split("---", 2)
    block = parts[1] if len(parts) >= 3 else ""
    body = (parts[2] if len(parts) >= 3 else text).lower()
    if "chronicle_identity" not in block:
        errs.append(f"persona {name}: front-matter missing 'chronicle_identity'")
    for tok in PERSONA_MECHANIC_TOKENS:
        if tok in body:
            errs.append(f"persona {name}: body names a system mechanic ('{tok}') — "
                        f"personas are voice-only (never mechanics)")
    return errs


def main(argv=None):
    ap = argparse.ArgumentParser(prog="validate-adapter")
    ap.add_argument("paths", nargs="+")
    ap.add_argument("--all", action="store_true",
                    help="treat each path as a root and validate every subdir with an adapter.md / persona.md")
    ap.add_argument("--personas", action="store_true",
                    help="validate persona.md files instead of adapters")
    a = ap.parse_args(argv)

    errs = []
    if a.personas:
        if a.all:
            targets = [d for root in a.paths for d in sorted(glob.glob(os.path.join(root, "*")))
                       if os.path.isfile(os.path.join(d, "persona.md"))]
        else:
            targets = [p.rstrip("/") for p in a.paths]
        for t in targets:
            errs += validate_persona(os.path.join(t, "persona.md"))
        kind = "persona"
    else:
        if a.all:
            root = a.paths[0]
            targets = [d for d in sorted(glob.glob(os.path.join(root, "*")))
                       if os.path.isfile(os.path.join(d, "adapter.md"))]
        else:
            targets = [p.rstrip("/") for p in a.paths]
            root = os.path.dirname(targets[0]) if targets else "."
        for t in targets:
            errs += validate_adapter(t, root)
        kind = "adapter"

    if errs:
        for e in errs:
            print(f"FAIL {e}")
        sys.exit(1)
    print(f"OK {len(targets)} {kind}(s) valid")


if __name__ == "__main__":
    main()
