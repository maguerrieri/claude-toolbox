#!/usr/bin/env python3
"""gm dice CLI — true-RNG roller. Standard library only.

Usage:
  roll "<expr>" [--seed N] [--json] [--adv | --dis]
  roll table <file> [--n N] [--seed N] [--json]
  roll oracle --table <path> [--seed N] [--json]   (deprecated alias of table)
  roll ironsworn-action [--stat N] [--adds N] [--seed N] [--json]
  roll ironsworn-progress --boxes N [--seed N] [--json]

Expression grammar:  NdX[kh M | kl M][!][+M | -M]
  N            number of dice (default 1)        e.g.  d20, 2d6
  dX           X-sided dice
  khM / klM    keep highest / lowest M dice      e.g.  4d6kh3
  !            exploding: a die showing its max rolls again and adds (capped)
  +M / -M      flat modifier

Production rolls use `secrets` (crypto RNG); `--seed` swaps in a deterministic
RNG for tests only. Every roll prints its dice and math (trust through
visibility); `--json` emits a machine-readable object.
"""
import argparse
import json
import re
import secrets
import sys

EXPLODE_CAP = 100

EXPR = re.compile(
    r"^(?P<n>\d*)d(?P<x>\d+)(?P<kd>k[hl]\d+)?(?P<exp>!)?(?P<mod>[+-]\d+)?$"
)
SIMPLE = re.compile(r"^(?P<n>\d*)d(?P<x>\d+)(?P<mod>[+-]\d+)?$")
# NOTE: duplicated in bin/validate-adapter — keep in sync.
TABLE_ENTRY = re.compile(r"^- (?:\[(?P<w>\d+)\]\s*)?(?P<text>.*)$")


def _make_rng(seed):
    if seed is None:
        return None
    import random
    return random.Random(seed)


def _die(sides, rng):
    if sides < 1:
        raise ValueError("dice need at least 1 side")
    return rng.randint(1, sides) if rng is not None else 1 + secrets.randbelow(sides)


def _roll_one(sides, exploding, rng):
    """Roll a single die, summing explosions. Exploding is skipped for d1 so it
    cannot loop forever (a d1 always shows its max)."""
    total = _die(sides, rng)
    if exploding and sides > 1:
        last, count = total, 0
        while last == sides and count < EXPLODE_CAP:
            last = _die(sides, rng)
            total += last
            count += 1
    return total


def roll_expr(expr, seed=None):
    m = EXPR.match(expr.replace(" ", ""))
    if not m:
        raise ValueError(f"bad dice expression: {expr!r}")
    n = int(m["n"] or 1)
    if n < 1:
        raise ValueError("must roll at least 1 die")
    x = int(m["x"])
    mod = int(m["mod"] or 0)
    exploding = bool(m["exp"])
    rng = _make_rng(seed)
    rolls = [_roll_one(x, exploding, rng) for _ in range(n)]
    kept = list(rolls)
    if m["kd"]:
        keep_high = m["kd"][1] == "h"
        keep_n = int(m["kd"][2:])
        kept = sorted(rolls, reverse=keep_high)[:keep_n]
    return {
        "expr": expr,
        "rolls": rolls,
        "kept": kept,
        "modifier": mod,
        "total": sum(kept) + mod,
    }


def human_expr(r):
    parts = [f"\U0001F3B2 {r['expr']} -> {r['rolls']}"]
    if r["kept"] != r["rolls"]:
        parts.append(f"keep {r['kept']}")
    if r["modifier"]:
        parts.append(f"{r['modifier']:+d}")
    parts.append(f"= {r['total']}")
    return " ".join(parts)


def parse_table(text):
    """Block rule: an entry is a top-level '- ' item plus its indented
    continuation lines, until the next top-level '- '. '- [w] ' sets weight."""
    entries = []
    for line in text.splitlines():
        m = TABLE_ENTRY.match(line)
        if m:                                   # top-level entry start
            entries.append({"weight": int(m["w"] or 1), "lines": [m["text"]]})
        elif entries and line[:1].isspace() and line.strip():
            entries[-1]["lines"].append(line.strip())   # indented continuation
        # else: header / blank / top-level prose -> ignored
    for e in entries:
        e["entry"] = "\n".join(e.pop("lines")).rstrip()
    return entries


def roll_table(path, n=1, seed=None):
    entries = parse_table(open(path).read())
    if not entries:
        raise ValueError(f"no entries in table: {path}")
    if any(e["weight"] < 1 for e in entries):
        raise ValueError(f"table entry weight must be >= 1: {path}")
    rng = _make_rng(seed)
    total, pool, rolls, picks = sum(e["weight"] for e in entries), list(entries), [], []
    for _ in range(min(n, len(entries))):
        t = sum(e["weight"] for e in pool)
        face = rng.randint(1, t) if rng is not None else 1 + secrets.randbelow(t)
        acc = 0
        for i, e in enumerate(pool):
            acc += e["weight"]
            if face <= acc:
                rolls.append(face); picks.append(e["entry"]); pool.pop(i)
                break
    return {"table": path, "total": total, "n": n, "rolls": rolls, "picks": picks}


def human_table(r):
    if len(r["picks"]) == 1:
        return f"\U0001F3B2 table {r['rolls'][0]}/{r['total']} -> {r['picks'][0]}"
    head = f"\U0001F3B2 table x{len(r['picks'])} of {r['total']}:"
    return "\n".join([head, *(f"  - {p}" for p in r["picks"])])


def _expr_main(argv):
    ap = argparse.ArgumentParser(prog="roll")
    ap.add_argument("expr")
    ap.add_argument("--seed", type=int)
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--adv", action="store_true")
    ap.add_argument("--dis", action="store_true")
    a = ap.parse_args(argv)
    expr = a.expr
    if a.adv or a.dis:
        m = SIMPLE.match(expr.replace(" ", ""))
        if not m:
            sys.exit("roll: --adv/--dis needs a simple NdX±M expression")
        expr = f"2d{m['x']}k{'h' if a.adv else 'l'}1{m['mod'] or ''}"
    try:
        r = roll_expr(expr, a.seed)
    except (ValueError, OSError) as e:
        sys.exit(f"roll: {e}")
    print(json.dumps(r) if a.json else human_expr(r))


def _oracle_main(argv):
    ap = argparse.ArgumentParser(prog="roll oracle")
    ap.add_argument("--table", required=True)
    ap.add_argument("--seed", type=int)
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    _table_main([a.table, *(["--seed", str(a.seed)] if a.seed is not None else []),
                 *(["--json"] if a.json else [])])


def _table_main(argv):
    ap = argparse.ArgumentParser(prog="roll table")
    ap.add_argument("file")
    ap.add_argument("--n", type=int, default=1)
    ap.add_argument("--seed", type=int)
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    try:
        r = roll_table(a.file, n=a.n, seed=a.seed)
    except (OSError, ValueError) as e:
        sys.exit(f"roll: {e}")
    print(json.dumps(r) if a.json else human_table(r))


def roll_action(stat=0, adds=0, seed=None, challenge_sides=10, action_die=None, challenge=None):
    """Ironsworn action roll: 1d6 + stat + adds (capped at 10) vs two challenge dice.
    Beats both -> strong hit; beats one -> weak hit; beats neither -> miss.
    Equal challenge dice -> a 'match'. --action-die / --challenge inject dice (testing)."""
    rng = _make_rng(seed)
    ad = action_die if action_die is not None else _die(6, rng)
    score = min(10, ad + stat + adds)
    ch = list(challenge) if challenge is not None else [_die(challenge_sides, rng), _die(challenge_sides, rng)]
    beats = sum(1 for c in ch if score > c)
    outcome = "strong hit" if beats == 2 else "weak hit" if beats == 1 else "miss"
    return {"action_die": ad, "stat": stat, "adds": adds, "score": score,
            "challenge": ch, "outcome": outcome, "match": ch[0] == ch[1]}


def human_action(r):
    tag = " (match!)" if r["match"] else ""
    return (f"\U0001F3B2 action {r['action_die']}{r['stat'] + r['adds']:+d} = {r['score']} "
            f"vs {r['challenge']} -> {r['outcome'].upper()}{tag}")


def _action_main(argv):
    ap = argparse.ArgumentParser(prog="roll ironsworn-action")
    ap.add_argument("--stat", type=int, default=0)
    ap.add_argument("--adds", type=int, default=0)
    ap.add_argument("--seed", type=int)
    ap.add_argument("--challenge-sides", type=int, default=10)
    ap.add_argument("--action-die", type=int, help="inject the action die (testing)")
    ap.add_argument("--challenge", type=int, nargs=2, help="inject challenge dice (testing)")
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    r = roll_action(stat=a.stat, adds=a.adds, seed=a.seed, challenge_sides=a.challenge_sides,
                    action_die=a.action_die, challenge=a.challenge)
    print(json.dumps(r) if a.json else human_action(r))


def roll_progress(boxes, seed=None, challenge_sides=10, challenge=None):
    """Ironsworn progress move: compare filled progress boxes (0-10) to two challenge
    dice. Beats both -> strong hit; one -> weak hit; neither -> miss. No action die."""
    rng = _make_rng(seed)
    score = max(0, min(10, boxes))
    ch = list(challenge) if challenge is not None else [_die(challenge_sides, rng), _die(challenge_sides, rng)]
    beats = sum(1 for c in ch if score > c)
    outcome = "strong hit" if beats == 2 else "weak hit" if beats == 1 else "miss"
    return {"progress": score, "challenge": ch, "outcome": outcome, "match": ch[0] == ch[1]}


def human_progress(r):
    tag = " (match!)" if r["match"] else ""
    return f"\U0001F3AF progress {r['progress']} vs {r['challenge']} -> {r['outcome'].upper()}{tag}"


def _progress_main(argv):
    ap = argparse.ArgumentParser(prog="roll ironsworn-progress")
    ap.add_argument("--boxes", type=int, required=True)
    ap.add_argument("--seed", type=int)
    ap.add_argument("--challenge-sides", type=int, default=10)
    ap.add_argument("--challenge", type=int, nargs=2, help="inject challenge dice (testing)")
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args(argv)
    r = roll_progress(boxes=a.boxes, seed=a.seed, challenge_sides=a.challenge_sides, challenge=a.challenge)
    print(json.dumps(r) if a.json else human_progress(r))


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv or argv[0] in ("-h", "--help"):
        print((__doc__ or "").strip())
        return
    if argv[0] == "oracle":
        _oracle_main(argv[1:])
    elif argv[0] == "table":
        _table_main(argv[1:])
    elif argv[0] == "ironsworn-action":
        _action_main(argv[1:])
    elif argv[0] == "ironsworn-progress":
        _progress_main(argv[1:])
    else:
        _expr_main(argv)


if __name__ == "__main__":
    main()
